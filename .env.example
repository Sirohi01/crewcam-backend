PORT=8000
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=
CORS_ORIGIN=
# Base domain whose subdomains (e.g. partner1.crewcam.com) are allowed to call the API
# with credentials for white-label tenant login. Leave blank to disable subdomain CORS.
CORS_ORIGIN_SUFFIX=
NODE_ENV=development
USD_TO_INR_RATE=83.5
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Required for sending company welcome / credential-reset emails (Super Admin > Companies)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Login URL embedded in credential emails sent to newly provisioned companies
FRONTEND_LOGIN_URL=https://app.crewcam.com/login

# Required for Setup Fee & Subscription checkout (Super Admin > Setup Fees/Subscriptions/Invoices).
# Without these, invoice checkout returns 503 and Super Admin can still mark invoices paid manually.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# From the Razorpay Dashboard webhook config — required to verify POST /api/v1/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=
# From the Stripe Dashboard webhook config — required to verify POST /api/v1/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
